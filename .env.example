# ========================================
# Authentication Configuration
# ========================================
# Clerk Authentication
# Get these from your Clerk Dashboard (https://dashboard.clerk.dev)
CLERK_SECRET_KEY="sk_test_4Prilr3Yiq6w8VVGtxEwqnFYNGwGbziY7Ql5okWMI5"

