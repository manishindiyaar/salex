# ========================================
# WhatsApp Cloud API Configuration
# ========================================
# Meta WhatsApp Cloud API
# Get these from Facebook Developer Console
WHATSAPP_API_TOKEN="your-whatsapp-api-token-here"
WHATSAPP_PHONE_NUMBER_ID="your-phone-number-id-here"
WHATSAPP_BUSINESS_ACCOUNT_ID="your-business-account-id-here"
WHATSAPP_WEBHOOK_VERIFY_TOKEN="your-webhook-verify-token-here"

# ========================================
# SMS Configuration
# ========================================
# Twilio SMS Fallback
# Get these from your Twilio Console
TWILIO_ACCOUNT_SID="your-twilio-account-sid-here"
TWILIO_AUTH_TOKEN="your-twilio-auth-token-here"
TWILIO_PHONE_NUMBER="+1234567890"

# ========================================
# Push Notifications Configuration
# ========================================
# Firebase Cloud Messaging (FCM)
# Get these from Firebase Console
FCM_SERVER_KEY="your-fcm-server-key-here"
FCM_PROJECT_ID="your-firebase-project-id-here"

# ========================================
# Cache Configuration
# ========================================
# Redis Cache (Optional for development)
REDIS_URL="redis://localhost:6379"

# ========================================
# Serverless Redis Configuration (Upstash)
# ========================================
# Get these from https://upstash.com console
UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-redis-token-here"

# WhatsApp Session Management
WHATSAPP_SESSION_TTL=600              # 10 minutes (in seconds)
WHATSAPP_SESSION_PREFIX="wa_session"   # Redis key prefix
WHATSAPP_BUSINESS_IDENTIFIER_PREFIX="S" # Business code prefix (S1234)

# ========================================
# Application Configuration
# ========================================
# API Server Configuration
API_PORT=3000
API_HOST="localhost"

# Frontend Configuration
EXPO_PUBLIC_API_URL="http://localhost:3000"

# Environment Mode
NODE_ENV="development"

# ========================================
# Development Tools Configuration
# ========================================
# Logging Level
LOG_LEVEL="debug"

# Enable API Documentation (Swagger)
ENABLE_SWAGGER="true"

# ========================================
# Local Development Notes
# ========================================
# 1. Start Supabase: supabase start
# 2. Copy this file to .env and fill in your values
# 3. Run database migrations: pnpm db:push
# 4. Start development servers: pnpm dev

# Required Services for Local Development:
# - Supabase (Database): http://localhost:54321
# - Supabase Studio: http://localhost:54323
# - Redis (Optional): redis://localhost:6379
# - API Server: http://localhost:3000
# - React Native Metro: http://localhost:8081