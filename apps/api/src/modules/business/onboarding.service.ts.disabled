  async getServiceTemplatesByBusinessType() {
    return {
      SALON: {
        templates: getServiceTemplatesByBusinessType('SALON'),
        message: 'Perfect for salons offering haircuts, styling, and beauty services',
      },
      SPA: {
        templates: getServiceTemplatesByBusinessType('SPA'),
        message: 'Excellent for spas with wellness and relaxation services',
      },
      BARBER_SHOP: {
        templates: getServiceTemplatesByBusinessType('BARBER_SHOP'),
        message: 'Ideal for barbershops focusing on men\'s grooming',
      },
      CLINIC: {
        templates: getServiceTemplatesByBusinessType('CLINIC'),
        message: 'Great for skincare clinics and aesthetic centers',
      },
    };
  }
}