import { Injectable, NotFoundException, ConflictException } from '@nestjs/common';
import { PrismaService } from '../../core/prisma.service';
import { CreateOnboardingBusinessDto } from './dto/onboarding-business.dto';
import { OnboardingStatus, OnboardingMetrics, StepValidation } from './dto/onboarding-status.dto';
import { Business, Service } from 'shared-types';
import { BulkCreateServicesDto, getServiceTemplatesByBusinessType } from './../service/dto/bulk-service.dto';
import { v4 as uuidv4 } from 'uuid';

@Injectable()
export class OnboardingService {
  constructor(private readonly prisma: PrismaService) {}

  async createBusinessWithOnboarding(userId: string, data: CreateOnboardingBusinessDto): Promise<{
    business: Business;
    services: Service[];
    onboarding: OnboardingStatus;
  }> {
    const { services, onboardingProgress, ...businessData } = data;
    
    // Validate business type and create appropriate records
    const businessType = businessData.businessType;
    
    // Start database transaction
    const result = await this.prisma.$transaction(async (tx) => {
      // Create business
      const business = await tx.business.create({
        data: {
          id: uuidv4(),
          ownerId: userId,
          name: businessData.name,
          businessType,
          phoneNumber: businessData.contactInfo?.primaryPhone || '',
          address: `${businessData.address.street}, ${businessData.address.city}, ${businessData.address.state} ${businessData.address.zip}`,
          hoursOfOperation: businessData.hoursOfOperation,
          description: businessData.description || '',
          isVerified: false,
          isPublished: false,
          createdAt: new Date(),
          updatedAt: new Date(),
        },
      });

      // Create salon record based on business type
      if (businessType === 'SALON') {
        await tx.salon.create({
          data: {
            id: uuidv4(),
            businessId: business.id,
          },
        });
      }

      // Create services
      const createdServices: Service[] = [];
      for (const service of services) {
        const createService = await tx.service.create({
          data: {
            id: uuidv4(),
            businessId: business.id,
            name: service.name,
            price: service.price,
            durationMinutes: service.durationMinutes,
            description: service.description || '',
            createdAt: new Date(),
            updatedAt: new Date(),
          },
        });
        createdServices.push(createService);
      }

      // Create onboarding status
      const onboardingStatus: OnboardingStatus = await this.createOnboardingStatus(
        business.id,
        userId,
        businessData,
        services
      );

      return { business, services: createdServices, onboarding: onboardingStatus };
    });

    return result;
  }

  async createOnboardingStatus(
    businessId: string,
    userId: string,
    businessData: any,
    services: any[]
  ): Promise<OnboardingStatus> {
    const now = new Date().toISOString();
    
    const onboardingStatus: OnboardingStatus = {
      id: uuidv4(),
      businessId,
      userId,
      totalSteps: 5,
      completedSteps: ['step5_review'], // Mark as completed since we're creating complete business
      currentStep: 'completed',
      progress: 100,
      step1: {
        businessName: businessData.name,
        tagline: businessData.tagline || '',
        logoUrl: businessData.logoUrl || '',
        description: businessData.description || '',
        completedAt: now,
      },
      step2: {
        primaryPhone: businessData.contactInfo?.primaryPhone || '',
        whatsApp: businessData.contactInfo?.whatsApp || '',
        address: {
          street: businessData.address?.street || '',
          city: businessData.address?.city || '',
          state: businessData.address?.state || '',
          zip: businessData.address?.zip || '',
          country: businessData.address?.country || 'IN',
          latitude: businessData.address?.latitude,
          longitude: businessData.address?.longitude,
        },
        website: businessData.socialLinks?.website || '',
        completedAt: now,
      },
      step3: {
        services: services.map(s => ({
          name: s.name,
          price: s.price,
          duration: s.durationMinutes,
          category: s.category || 'General',
          description: s.description || '',
        })),
        completedAt: now,
      },
      step4: {
        hoursOfOperation: businessData.hoursOfOperation || {},
        completedAt: now,
      },
      step5: {
        reviewCompleted: true,
        qrCodeGenerated: true,
        servicesReviewed: true,
        completedAt: now,
      },
      sessionData: {
        startedAt: now,
        lastUpdatedAt: now,
        estimatedCompletionTime: new Date(Date.now() + 5 * 60 * 1000).toISOString(),
        platform: 'onboarding-complete',
      },
      completionTime: 300, // 5 minutes in seconds
      createdAt: now,
      updatedAt: now,
    };

    await this.prisma.onboardingStatus.create({
      data: {
        id: onboardingStatus.id,
        businessId,
        userId,
        status: JSON.stringify(onboardingStatus),
        currentStep: 'completed',
        progress: 100,
        completedSteps: JSON.stringify(['step1', 'step2', 'step3', 'step4', 'step5']),
        createdAt: new Date(),
        updatedAt: new Date(),
      },
    });

    return onboardingStatus;
  }

  async getOnboardingStatus(businessId: string, userId: string): Promise<OnboardingStatus> {
    const record = await this.prisma.onboardingStatus.findFirst({
      where: { businessId, userId },
      orderBy: { createdAt: 'desc' },
    });

    if (!record) {
      throw new NotFoundException('Onboarding status not found');
    }

    return JSON.parse(record.status);
  }

  async updateOnboardingStep(
    businessId: string,
    userId: string,
    step: string,
    data: any
  ): Promise<OnboardingStatus> {
    const record = await this.prisma.onboardingStatus.findFirst({
      where: { businessId, userId },
    });

    if (!record) {
      throw new NotFoundException('Onboarding status not found');
    }

    const currentStatus = JSON.parse(record.status) as OnboardingStatus;
    
    // Update specific step data
    const now = new Date().toISOString();
    
    switch (step) {
      case 'step1':
        currentStatus.step1 = { ...data, completedAt: now };
        currentStatus.completedSteps = [...new Set([...currentStatus.completedSteps, 'step1'])];
        break;
      case 'step2':
        currentStatus.step2 = { ...data, completedAt: now };
        currentStatus.completedSteps = [...new Set([...currentStatus.completedSteps, 'step2'])];
        break;
      case 'step3':
        currentStatus.step3 = { ...data, completedAt: now };
        currentStatus.completedSteps = [...new Set([...currentStatus.completedSteps, 'step3'])];
        break;
      case 'step4':
        currentStatus.step4 = { ...data, completedAt: now };
        currentStatus.completedSteps = [...new Set([...currentStatus.completedSteps, 'step4'])];
        break;
      case 'step5':
        currentStatus.step5 = { ...data, completedAt: now };
        currentStatus.completedSteps = [...new Set([...currentStatus.completedSteps, 'step5'])];
        break;
    }

    currentStatus.progress = (currentStatus.completedSteps.length / currentStatus.totalSteps) * 100;
    currentStatus.currentStep = step;
    currentStatus.updatedAt = new Date().toISOString();
    currentStatus.sessionData.lastUpdatedAt = new Date().toISOString();

    await this.prisma.onboardingStatus.update({
      where: { id: record.id },
      data: {
        status: JSON.stringify(currentStatus),
        currentStep: step,
        progress: currentStatus.progress,
        completedSteps: JSON.stringify(currentStatus.completedSteps),
        updatedAt: new Date(),
      },
    });

    return currentStatus;
  }

  async getServiceTemplates(businessType: string) {
    const templates = getServiceTemplatesByBusinessType(businessType);
    return {
      templates,
      businessType,
      customServices: true,
    };
  }

  async validateStep(step: string, businessId: string, userId: string): Promise<{ 
    isValid: boolean; 
    requiredFields: string[]; 
    missingFields: string[]; 
    canProceed: boolean; 
  }> {
    const record = await this.prisma.onboardingStatus.findFirst({
      where: { businessId, userId },
    });

    if (!record) {
      throw new NotFoundException('Onboarding status not found');
    }

    const currentStatus = JSON.parse(record.status) as OnboardingStatus;
    
    let requiredFields: string[] = [];
    let missingFields: string[] = [];
    let isValid = true;

    switch (step) {
      case 'step1':
        requiredFields = ['businessName', 'tagline'];
        missingFields = [];
        
        if (currentStatus.step1?.businessName?.length < 2) {
          missingFields.push('businessName');
        }
        if (currentStatus.step1?.tagline?.length > 200) {
          missingFields.push('tagline');
        }
        break;

      case 'step2':
        requiredFields = ['primaryPhone', 'address'];
        missingFields = [];
        
        if (!currentStatus.step2?.primaryPhone || !currentStatus.step2.primaryPhone.includes('+')) {
          missingFields.push('primaryPhone');
        }
        break;

      case 'step3':
        requiredFields = ['services'];
        missingFields = [];
        
        if (!currentStatus.step3?.services || currentStatus.step3.services.length === 0) {
          missingFields.push('services');
        }
        break;

      case 'step4':
        requiredFields = ['hoursOfOperation'];
        missingFields = [];
        
        if (!currentStatus.step4?.hoursOfOperation) {
          missingFields.push('hoursOfOperation');
        }
        break;

      case 'step5':
        isValid = currentStatus.completedSteps.includes('step4') && currentStatus.completedSteps.length === 5;
        break;
    }

    const canProceed = missingFields.length === 0;

    return {
      isValid,
      requiredFields,
      missingFields,
      canProceed,
    };
  }

  async resumeOnboarding(userId: string): Promise<OnboardingStatus | null> {
    const record = await this.prisma.onboardingStatus.findFirst({
      where: { userId },
      orderBy: { createdAt: 'desc' },
    });

    if (!record) return null;

    const status = JSON.parse(record.status) as OnboardingStatus;
    
    // Check if session is still valid (within 24 hours)
    const lastUpdated = new Date(status.sessionData.lastUpdatedAt);
    const now = new Date();
    const diffHours = (now.getTime() - lastUpdated.getTime()) / (1000 * 60 * 60);

    if (diffHours > 24) {
      return null; // Session expired
    }

    return status;
  }

  async startNewOnboarding(userId: string): Promise<OnboardingStatus> {
    // Clean up any existing incomplete onboarding
    await this.prisma.onboardingStatus.updateMany({
      where: { 
        userId,
        currentStep: { not: 'completed' }
      },
      data: { 
        status: '{ "expired": true }',
        currentStep: 'expired' 
      }
    });

    const initialStatus: Partial<OnboardingStatus> = {
      id: uuidv4(),
      businessId: '',
      userId,
      totalSteps: 5,
      completedSteps: [],
      currentStep: 'step1',
      progress: 0,
      step1: {
        businessName: '',
        tagline: '',
        logoUrl: '',
        description: '',
        completedAt: new Date().toISOString(),
      },
      step2: {
        primaryPhone: '',
        whatsApp: '',
        address: {
          street: '',
          city: '',
          state: '',
          zip: '',
          country: 'IN',
        },
        website: '',
        completedAt: new Date().toISOString(),
      },
      step3: {
        services: [],
        completedAt: new Date().toISOString(),
      },
      step4: {
        hoursOfOperation: {
          monday: { open: '09:00', close: '18:00', closed: false },
          tuesday: { open: '09:00', close: '18:00', closed: false },
          wednesday: { open: '09:00', close: '18:00', closed: false },
          thursday: { open: '09:00', close: '18:00', closed: false },
          friday: { open: '09:00', close: '18:00', closed: false },
          saturday: { open: '09:00', close: '18:00', closed: false },
          sunday: { open: '', close: '', closed: true },
        },
        completedAt: new Date().toISOString(),
      },
      step5: {
        reviewCompleted: false,
        qrCodeGenerated: false,
        servicesReviewed: false,
        completedAt: new Date().toISOString(),
      },
      sessionData: {
        startedAt: new Date().toISOString(),
        lastUpdatedAt: new Date().toISOString(),
        estimatedCompletionTime: new Date(Date.now() + 5 * 60 * 1000).toISOString(),
        platform: 'mobile',
      },
      completionTime: 0,
      createdAt: new Date().toISOString(),
      updatedAt: new Date().toISOString(),
    };

    await this.prisma.onboardingStatus.create({
      data: {
        id: initialStatus.id!,
        businessId: '',
        userId,
        status: JSON.stringify(initialStatus),
        currentStep: 'step1',
        progress: 0,
        completedSteps: JSON.stringify([]),
        createdAt: new Date(),
        updatedAt: new Date(),
      },
    });

    return initialStatus as unknown as OnboardingStatus;
  }

