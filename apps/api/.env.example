# Server Configuration
NODE_ENV=development
PORT=3001
PRISMA_QUERY_LOGS=false
ALLOWED_ORIGINS="https://salex-admin-dashboard.vercel.app"

# Supabase Cloud Configuration
# ============================
# Connection Pooler (port 6543) - Runtime queries
DATABASE_URL="postgres://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct Connection (port 5432) - Migrations
DIRECT_URL="postgres://postgres.YOUR-REF:YOUR-PASSWORD@db.YOUR-REF.supabase.co:5432/postgres"

# Supabase API Keys
SUPABASE_URL="https://YOUR-REF.supabase.co"
SUPABASE_ANON_KEY="YOUR-ANON-KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"
SUPABASE_JWT_SECRET="YOUR-JWT-SECRET"

# Twilio Configuration (OTP)
TWILIO_ACCOUNT_SID="YOUR-TWILIO-ACCOUNT-SID"
TWILIO_AUTH_TOKEN="YOUR-TWILIO-AUTH-TOKEN"
TWILIO_VERIFY_SERVICE_SID="YOUR-TWILIO-VERIFY-SERVICE-SID"

# Auth Feature Flags
PASSWORD_LOGIN_ENABLED=true
OTP_LOGIN_ENABLED=false
OTP_ALLOW_NEW_USER_SIGNUP=false

# WhatsApp Configuration
WHATSAPP_APP_SECRET="YOUR-WHATSAPP-APP-SECRET"
WHATSAPP_ACCESS_TOKEN="YOUR-WHATSAPP-ACCESS-TOKEN"
WHATSAPP_PHONE_NUMBER_ID="YOUR-WHATSAPP-PHONE-NUMBER-ID"
WHATSAPP_VERIFY_TOKEN="YOUR-WEBHOOK-VERIFY-TOKEN"
WHATSAPP_GRAPH_API_VERSION="v25.0"

# WhatsApp Mode: "production" | "simulator"
WHATSAPP_MODE="simulator"

# Channel Encryption (32 bytes hex = 64 chars for AES-256-GCM)
CHANNEL_ENCRYPTION_KEY=

# Flow Engine Configuration
# Set to "true" to route ALL conversations to the Flow_Engine (global cutover)
FLOW_ENGINE_GLOBAL_CUTOVER=false

# Simulator Configuration (development only)
SIMULATOR_DEFAULT_BUSINESS_ID=""
WEBHOOK_BASE_URL="http://localhost:3001"
