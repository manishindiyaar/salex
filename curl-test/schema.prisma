// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// ENUMS
// ========================================

enum BusinessType {
  SALON
  GENERAL_STORE
  FOOD_VENDOR
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED_BY_USER
  CANCELLED_BY_SALON
  COMPLETED
}

// ========================================
// CORE MODELS
// ========================================

model User {
  id           String   @id @default(cuid())
  clerkUserId  String   @unique @map("clerk_user_id")
  phoneNumber  String   @map("phone_number")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  businesses Business[]

  @@map("users")
}

model Business {
  id               String      @id @default(cuid())
  ownerId          String      @map("owner_id")
  name             String
  businessType     BusinessType @map("business_type")
  phoneNumber      String      @map("phone_number")
  address          String
  hoursOfOperation Json?       @map("hours_of_operation")
  routingCode      String?     @unique @map("routing_code") @db.VarChar(4)
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  // Relationships
  owner    User       @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  salon    Salon?
  services Service[]
  bookings Booking[]
  customerSessions CustomerSession[]
  whatsappConversations WhatsAppConversation[]

  // Indexes
  @@index([routingCode])
  @@map("businesses")
}

model Salon {
  id         String @id @default(cuid())
  businessId String @unique @map("business_id")

  // Relationships
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("salons")
}

model Customer {
  id          String   @id @default(cuid())
  phoneNumber String   @unique @map("phone_number")
  name        String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relationships
  bookings Booking[]
  session  CustomerSession?
  whatsappConversations WhatsAppConversation[]

  @@map("customers")
}

model Service {
  id              String   @id @default(cuid())
  businessId      String   @map("business_id")
  name            String   @db.VarChar(50)
  price           Decimal  @db.Decimal(10, 2)
  durationMinutes Int      @map("duration_minutes")
  description     String?  @db.VarChar(500)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relationships
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  bookings Booking[]

  // Constraints
  @@unique([businessId, name])  // Prevent duplicate service names per business
  @@index([businessId])         // Optimize service lookups by business
  @@map("services")
}

model Booking {
  id         String        @id @default(cuid())
  businessId String        @map("business_id")
  customerId String        @map("customer_id")
  serviceId  String        @map("service_id")
  status     BookingStatus @default(PENDING)
  
  // Booking Details
  scheduledAt DateTime @map("scheduled_at")
  notes       String?
  
  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service  Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("bookings")
}

// ========================================
// WHATSAPP WEB SIMULATOR MODELS (Legacy - Keep for backward compatibility)
// ========================================

model CustomerSession {
  id               String   @id @default(cuid())
  customerPhone    String   @map("customer_phone")
  businessId       String?  @map("business_id")
  currentState     String   @default("INITIAL") @map("current_state")
  sessionData      Json?    @map("session_data")
  lastMessageAt    DateTime @default(now()) @map("last_message_at")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relationships
  customer         Customer? @relation(fields: [customerPhone], references: [phoneNumber], onDelete: Cascade)
  business         Business? @relation(fields: [businessId], references: [id], onDelete: Cascade)
  messages         SimulatorMessage[]

  @@unique([customerPhone])
  @@index([customerPhone, businessId])
  @@index([expiresAt])
  @@map("customer_sessions")
}

model SimulatorMessage {
  id               String    @id @default(cuid())
  sessionId        String    @map("session_id")
  messageId        String    @unique @map("message_id")
  fromPhone        String    @map("from_phone")
  toPhone          String    @map("to_phone")
  messageType      String    @map("message_type")
  content          Json
  timestamp        DateTime  @default(now())
  isFromCustomer   Boolean   @map("is_from_customer")
  delivered        Boolean   @default(false)
  read             Boolean   @default(false)

  // Relationships
  session          CustomerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
  @@index([fromPhone, toPhone])
  @@map("simulator_messages")
}

// ========================================
// WHATSAPP CLOUD API COMPATIBLE MODELS (New webhook-based approach)
// ========================================

model WhatsAppConversation {
  id               String   @id @default(cuid())
  customerPhone    String   @map("customer_phone")
  businessId       String   @map("business_id")
  state            String   @default("GREETING") // GREETING, SERVICE_SELECTION, TIME_SELECTION, BOOKING_CONFIRMATION
  context          Json?    // Store booking progress, selected services, etc.
  lastMessageAt    DateTime @default(now()) @map("last_message_at")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relationships
  customer         Customer? @relation(fields: [customerPhone], references: [phoneNumber], onDelete: Cascade)
  business         Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  messages         WhatsAppMessage[]

  @@unique([customerPhone, businessId])
  @@index([customerPhone])
  @@index([businessId])
  @@index([expiresAt])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id                    String   @id @default(cuid())
  conversationId        String   @map("conversation_id")
  whatsappMessageId     String?  @unique @map("whatsapp_message_id") // For real WhatsApp integration
  direction             String   // 'INCOMING' | 'OUTGOING'
  messageType           String   @map("message_type") // 'text' | 'interactive' | 'image'
  content               Json     // Full WhatsApp message payload
  status                String   @default("sent") // sent, delivered, read
  isSimulator           Boolean  @default(true) @map("is_simulator") // Track if from simulator
  createdAt             DateTime @default(now()) @map("created_at")

  // Relationships
  conversation          WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([whatsappMessageId])
  @@index([isSimulator])
  @@map("whatsapp_messages")
}