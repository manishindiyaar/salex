# Supabase Cloud Database Configuration
# =====================================
PRISMA_QUERY_LOGS=false

# Connection Pooler (port 6543) - Used for runtime queries
# Format: postgres://[user]:[password]@aws-0-[region].pooler.supabase.com:6543/[db_name]?pgbouncer=true&connection_limit=10&pool_timeout=10
DATABASE_URL="postgres://postgres.YOUR-REF:YOUR-PASSWORD@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10&pool_timeout=10"

# Direct Connection (port 5432) - Used for migrations and schema changes
# Format: postgres://[user]:[password]@db.YOUR-REF.supabase.co:5432/[db_name]
DIRECT_URL="postgres://postgres.YOUR-REF:YOUR-PASSWORD@db.YOUR-REF.supabase.co:5432/postgres"
