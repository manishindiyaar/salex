// Prisma Schema for Salex Backend
// Uses Supabase Cloud PostgreSQL with Connection Pooler

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Connection Pooler (port 6543) for runtime
  directUrl = env("DIRECT_URL") // Direct Connection (port 5432) for migrations
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  OWNER
  STAFF
}

enum BookingStatus {
  PENDING
  CONFIRMED
  REJECTED
  CANCELLED_BY_USER
  CANCELLED_BY_SALON
  COMPLETED
}

enum PaymentMode {
  CASH
  UPI
  OTHER
}

enum SubscriptionPlan {
  BASIC
  PRO
  CUSTOM
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  GRACE
  EXPIRED
  CANCELLED
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

enum BusinessCategory {
  SALON
  BEAUTY_PARLOR
  SPA
  CLINIC
  FITNESS
  OTHER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DISABLED
}

enum AuthMethodType {
  PASSWORD
  PHONE_OTP
}

enum AuthMethodStatus {
  ENABLED
  DISABLED
  PENDING_VERIFICATION
}

enum PhoneVerificationSource {
  ADMIN_ATTESTED
  OTP_PROVIDER
}

enum FlowStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ============================================
// CORE MODELS
// ============================================

/// Merchant/Salon owner
model User {
  id                      String                   @id @default(cuid())
  phone                   String                   @unique
  role                    UserRole                 @default(OWNER)
  status                  UserStatus               @default(ACTIVE)
  mustChangePassword      Boolean                  @default(false)
  phoneVerifiedAt         DateTime?
  phoneVerificationSource PhoneVerificationSource?
  createdByAdminId        String?
  lastLoginAt             DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt

  businesses  Business[]
  authMethods AuthMethod[]

  @@index([status])
  @@index([createdByAdminId])
}

/// Authentication method for a user (password, OTP, etc.)
model AuthMethod {
  id         String           @id @default(cuid())
  userId     String
  type       AuthMethodType
  identifier String
  secretHash String?
  status     AuthMethodStatus @default(ENABLED)
  verifiedAt DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, identifier])
  @@index([userId, type, status])
}

/// OTP storage for phone verification
model Otp {
  id        String   @id @default(cuid())
  phone     String // E.164 format
  code      String // The 6-digit code
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
}

/// WhatsApp customer (no app required)
model Customer {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  name        String?
  isBlocked   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookings      Booking[]
  conversations WhatsAppConversation[]
  sessions      CustomerSession[]
}

/// Business/Salon entity
model Business {
  id                    String           @id @default(cuid())
  ownerId               String
  name                  String
  phoneNumber           String
  routingCode           String?          @unique @db.VarChar(4)
  slug                  String?          @unique
  category              BusinessCategory @default(SALON) // NEW
  hoursOfOperation      Json?
  maxConcurrentBookings Int              @default(1)
  isAcceptingOrders     Boolean          @default(true)
  isActive              Boolean          @default(true) // NEW - Admin toggle
  onboardingCompleted   Boolean          @default(false)
  whatsappSettings      Json? // { "flowEngineEnabled": boolean, ... } — segmentation flag (Req 11.1)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  owner                User                   @relation(fields: [ownerId], references: [id])
  subscription         Subscription? // NEW - One-to-one relation
  services             Service[]
  bookings             Booking[]
  conversations        WhatsAppConversation[]
  sessions             CustomerSession[]
  resources            Resource[]
  staff                Staff[]
  businessCustomers    BusinessCustomer[]
  bookingStatusHistory BookingStatusHistory[]
  bookingAttempts      BookingAttempt[]
  supportNotes         SupportNote[]
  whatsAppChannel      WhatsAppChannel?
  whatsAppFlows        WhatsAppFlow[]

  @@index([routingCode])
  @@index([category])
  @@index([isActive])
}

// ============================================
// SUBSCRIPTION & PAYMENT MODELS
// ============================================

/// Subscription model for business plans and billing
model Subscription {
  id                 String             @id @default(cuid())
  businessId         String             @unique
  plan               SubscriptionPlan   @default(BASIC)
  status             SubscriptionStatus @default(TRIAL)
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  business Business        @relation(fields: [businessId], references: [id])
  payments PaymentRecord[]

  @@index([status])
  @@index([currentPeriodEnd])
}

/// Payment record for manual payment tracking
model PaymentRecord {
  id             String   @id @default(cuid())
  subscriptionId String
  amount         Decimal  @db.Decimal(10, 2)
  currency       String   @default("INR")
  paymentMethod  String // "gpay" | "upi" | "bank_transfer"
  transactionRef String?
  periodStart    DateTime
  periodEnd      DateTime
  notes          String?
  recordedBy     String? // Admin user ID
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId])
  @@index([createdAt])
}

// ============================================
// ADMIN USER & AUDIT LOG MODELS
// ============================================

/// Admin user for platform management
model AdminUser {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String
  role      AdminRole @default(ADMIN)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  auditLogs    AuditLog[]
  supportNotes SupportNote[]
}

/// Audit log for tracking admin actions
model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  action     String // "TOGGLE_BUSINESS", "RECORD_PAYMENT", etc.
  entityType String // "Business", "Subscription", etc.
  entityId   String
  changes    Json // { previousValue, newValue }
  reason     String?
  createdAt  DateTime @default(now())

  admin AdminUser @relation(fields: [adminId], references: [id])

  @@index([adminId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
}

/// Service offered by a business
model Service {
  id              String   @id @default(cuid())
  businessId      String
  name            String   @db.VarChar(100)
  description     String?  @db.VarChar(500)
  price           Decimal  @db.Decimal(10, 2)
  durationMinutes Int      @default(30)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id])
  bookingItems BookingItem[]

  @@unique([businessId, name])
}

// ============================================
// RESOURCE & STAFF MODELS
// ============================================

/// Physical bookable resource (chair, bed, room, station)
model Resource {
  id           String   @id @default(cuid())
  businessId   String
  name         String   @db.VarChar(100)
  description  String?  @db.VarChar(500)
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  business   Business            @relation(fields: [businessId], references: [id])
  bookings   Booking[]
  staffLinks ResourceStaffLink[]

  @@unique([businessId, name])
  @@index([businessId, isActive])
}

/// Staff member who performs services
model Staff {
  id         String   @id @default(cuid())
  businessId String
  name       String   @db.VarChar(100)
  phone      String?  @db.VarChar(20)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business      Business            @relation(fields: [businessId], references: [id])
  bookings      Booking[]
  resourceLinks ResourceStaffLink[]

  @@unique([businessId, name])
  @@index([businessId, isActive])
}

/// Junction table for optional staff-resource linking
model ResourceStaffLink {
  id         String   @id @default(cuid())
  resourceId String
  staffId    String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  staff    Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([resourceId, staffId])
}

// ============================================
// BOOKING MODELS
// ============================================

/// Booking with multi-service support and resource/staff allocation
model Booking {
  id                 String        @id @default(cuid())
  businessId         String
  customerId         String?
  businessCustomerId String?
  resourceId         String?
  staffId            String?
  status             BookingStatus @default(PENDING)
  scheduledAt        DateTime
  endAt              DateTime
  totalPrice         Decimal       @default(0) @db.Decimal(10, 2)
  paymentMode        PaymentMode?
  notes              String?
  source             String? // "whatsapp" | "manual" | "walk-in"
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  business         Business               @relation(fields: [businessId], references: [id])
  customer         Customer?              @relation(fields: [customerId], references: [id])
  businessCustomer BusinessCustomer?      @relation(fields: [businessCustomerId], references: [id])
  resource         Resource?              @relation(fields: [resourceId], references: [id])
  staff            Staff?                 @relation(fields: [staffId], references: [id])
  items            BookingItem[]
  statusHistory    BookingStatusHistory[]

  @@index([businessId, scheduledAt])
  @@index([resourceId, scheduledAt])
  @@index([staffId, scheduledAt])
}

/// Pivot table for multi-service bookings with price snapshots
model BookingItem {
  id            String  @id @default(cuid())
  bookingId     String
  serviceId     String
  nameSnapshot  String
  priceSnapshot Decimal @db.Decimal(10, 2)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])
}

// ============================================
// WHATSAPP CONVERSATION MODELS
// ============================================

/// WhatsApp conversation state (stateless API pattern)
model WhatsAppConversation {
  id            String    @id @default(cuid())
  customerPhone String
  businessId    String?
  state         String    @default("GREETING")
  contextData   Json      @default("{}")
  version       Int       @default(0)
  lockedAt      DateTime?
  lockedBy      String?
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Version pinning (Req 5.2/5.3) — null => running DEFAULT_FLOW
  flowId      String?
  flowVersion Int?

  customer Customer?         @relation(fields: [customerPhone], references: [phoneNumber])
  business Business?         @relation(fields: [businessId], references: [id])
  messages WhatsAppMessage[]

  @@unique([customerPhone, businessId])
  @@index([customerPhone])
  @@index([businessId])
}

/// WhatsApp message audit trail
model WhatsAppMessage {
  id                String   @id @default(cuid())
  conversationId    String
  whatsappMessageId String?  @unique
  direction         String // "inbound" | "outbound"
  messageType       String // "text" | "interactive" | "button" | "template"
  content           Json
  status            String   @default("sent") // "sent" | "delivered" | "read" | "failed"
  createdAt         DateTime @default(now())

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

/// Durable inbound queue for production WhatsApp webhooks.
model WhatsAppInboundEvent {
  id              String    @id @default(cuid())
  waMessageId     String    @unique
  phoneNumberId   String?
  customerPhone   String
  businessId      String?
  messageType     String
  messageText     String?
  interactiveId   String?
  interactiveText String?
  payload         Json
  status          String    @default("PENDING")
  attempts        Int       @default(0)
  lockedAt        DateTime?
  lockedBy        String?
  nextAttemptAt   DateTime?
  error           String?
  createdAt       DateTime  @default(now())
  processedAt     DateTime?

  @@index([status, nextAttemptAt])
  @@index([customerPhone])
  @@index([businessId])
}

/// Durable outbox for WhatsApp messages sent to Meta.
model WhatsAppOutboundMessage {
  id                String    @id @default(cuid())
  idempotencyKey    String    @unique
  conversationId    String
  toPhone           String
  phoneNumberId     String?
  messageType       String
  payload           Json
  status            String    @default("PENDING")
  providerMessageId String?
  attempts          Int       @default(0)
  lockedAt          DateTime?
  lockedBy          String?
  nextAttemptAt     DateTime?
  error             String?
  createdAt         DateTime  @default(now())
  sentAt            DateTime?

  @@index([status, nextAttemptAt])
  @@index([conversationId])
}

/// Short-lived idempotent booking decision created before WhatsApp confirmation.
model BookingIntent {
  id             String   @id @default(cuid())
  conversationId String
  businessId     String
  customerPhone  String
  serviceIds     Json
  requestedTime  DateTime
  totalDuration  Int
  totalPrice     Decimal  @db.Decimal(10, 2)
  status         String   @default("PENDING")
  bookingId      String?
  idempotencyKey String   @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([conversationId])
  @@index([businessId])
  @@index([status, expiresAt])
}

/// Cross-process lock used by DB-backed WhatsApp workers.
model WhatsAppProcessingLock {
  lockKey   String   @id
  lockedAt  DateTime @default(now())
  lockedBy  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================
// SIMULATOR/DEV TOOLS MODELS
// ============================================

/// Customer session for simulator dev tools
model CustomerSession {
  id            String    @id @default(cuid())
  customerPhone String
  businessId    String?
  currentState  String    @default("GREETING")
  sessionData   Json      @default("{}")
  lastMessageAt DateTime  @default(now())
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  customer Customer?          @relation(fields: [customerPhone], references: [phoneNumber])
  business Business?          @relation(fields: [businessId], references: [id])
  messages SimulatorMessage[]

  @@unique([customerPhone, businessId])
}

/// Simulator message storage for polling
model SimulatorMessage {
  id             String   @id @default(cuid())
  sessionId      String
  messageId      String   @unique @default(cuid())
  fromPhone      String
  toPhone        String
  messageType    String // "text" | "interactive"
  content        Json
  timestamp      DateTime @default(now())
  isFromCustomer Boolean  @default(true)
  delivered      Boolean  @default(false)
  read           Boolean  @default(false)

  session CustomerSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

// ============================================
// FOUNDATION V2 MODELS
// ============================================

/// Global person identity (tied to phone number)
model Person {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  businessCustomers BusinessCustomer[]
}

/// Business-specific customer record
model BusinessCustomer {
  id               String    @id @default(cuid())
  businessId       String
  personId         String
  displayName      String?
  isBlocked        Boolean   @default(false)
  notes            String?
  preferences      Json?
  lastInteractedAt DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  business        Business         @relation(fields: [businessId], references: [id])
  person          Person           @relation(fields: [personId], references: [id])
  bookings        Booking[]
  bookingAttempts BookingAttempt[]

  @@unique([businessId, personId])
  @@index([businessId])
  @@index([personId])
}

/// Status history for bookings
model BookingStatusHistory {
  id            String         @id @default(cuid())
  bookingId     String
  businessId    String
  fromStatus    BookingStatus?
  toStatus      BookingStatus
  changedByType String // "SYSTEM" | "ADMIN" | "MERCHANT" | "CUSTOMER"
  changedById   String? // ID of the user/admin who changed it
  reason        String?
  createdAt     DateTime       @default(now())

  booking  Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  business Business @relation(fields: [businessId], references: [id])

  @@index([bookingId])
  @@index([businessId])
  @@index([createdAt])
}

/// Attempt log for booking flow
model BookingAttempt {
  id                 String   @id @default(cuid())
  businessId         String?
  businessCustomerId String?
  channel            String // "MERCHANT_APP" | "WHATSAPP" | "ADMIN"
  stage              String
  status             String // "STARTED" | "FAILED" | "SUCCEEDED"
  failureCode        String?
  failureMessage     String?
  context            Json?
  createdAt          DateTime @default(now())

  business         Business?         @relation(fields: [businessId], references: [id])
  businessCustomer BusinessCustomer? @relation(fields: [businessCustomerId], references: [id])

  @@index([businessId])
  @@index([businessCustomerId])
  @@index([status])
  @@index([createdAt])
}

/// Internal support notes for a business
model SupportNote {
  id         String   @id @default(cuid())
  businessId String
  adminId    String
  body       String
  status     String   @default("OPEN") // "OPEN" | "FOLLOW_UP" | "RESOLVED"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  business Business  @relation(fields: [businessId], references: [id])
  admin    AdminUser @relation(fields: [adminId], references: [id])

  @@index([businessId])
  @@index([adminId])
}

/// WhatsApp Channel configuration
model WhatsAppChannel {
  id                 String    @id @default(cuid())
  businessId         String?   @unique
  mode               String // "SHARED" | "DEDICATED"
  displayPhoneNumber String
  phoneNumberId      String    @unique
  wabaId             String?
  status             String    @default("PENDING") // "PENDING" | "CONNECTED" | "DISABLED" | "FAILED"
  accessToken        String? // AES-256-GCM encrypted, base64 encoded
  appSecret          String? // AES-256-GCM encrypted, base64 encoded
  lastTestedAt       DateTime?
  qualityRating      String?
  messagingLimit     String?
  lastInboundAt      DateTime?
  lastOutboundAt     DateTime?
  lastHealthCheckAt  DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  business Business? @relation(fields: [businessId], references: [id])

  @@index([businessId])
  @@index([phoneNumberId])
}

// ============================================
// WHATSAPP FLOW ENGINE MODELS
// ============================================

/// Versioned flow definition — one row per version per business (Req 1.2)
model WhatsAppFlow {
  id          String     @id @default(cuid())
  businessId  String
  name        String
  description String?
  version     Int        @default(1)
  status      FlowStatus @default(DRAFT)
  isActive    Boolean    @default(false) // Kept for backward compatibility (Req 11.1)
  entryNodeId String
  definition  Json // FlowDefinition payload (nodes + edges graph)
  createdBy   String? // owner userId who saved this version
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, version]) // retain history; no dup versions (Req 1.2)
  @@index([businessId, status]) // status-based queries (Req 3.4)
  @@index([businessId, isActive]) // fast "active flow for business" lookup (Req 1.3)
}

// ============================================
// FLOW SIMULATOR MODELS
// ============================================

/// Isolated simulation session for admin flow testing (Req 7.1, 7.5, 10.1)
model SimulationSession {
  id            String   @id @default(cuid())
  businessId    String
  flowId        String
  flowVersion   Int
  adminId       String
  currentNodeId String
  contextData   Json     @default("{}")
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages SimulationMessage[]

  @@index([businessId, adminId, lastMessageAt])
  @@index([lastMessageAt])
}

/// Messages exchanged during a simulation session
model SimulationMessage {
  id          String   @id @default(cuid())
  sessionId   String
  direction   String // "inbound" | "outbound"
  messageType String // "text" | "interactive"
  content     Json
  nodeId      String? // Which node produced/received this message
  timestamp   DateTime @default(now())

  session SimulationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, timestamp])
}
