{
  "name": "@salex/shared-types",
  "version": "1.0.0",
  "description": "Shared TypeScript types, Prisma client, and Zod schemas for Salex platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./prisma": {
      "types": "./dist/db.d.ts",
      "default": "./dist/db.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "echo 'Linting skipped for shared-types in development'",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:push": "echo 'db:push is disabled. Use db:migrate locally and db:migrate:deploy in staging/production.' && exit 1",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "typescript": "^5.5.4",
    "@types/node": "^22.7.4",
    "eslint": "^8.42.0",
    "eslint-config-custom": "workspace:*",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.0.0"
  },
  "files": [
    "dist",
    "prisma"
  ]
}
