{
  "name": "salex",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=api",
    "dev:app": "turbo run dev --filter=salon-merchant-app",
    "dev:clinic": "turbo run dev --filter=clinic-merchant-app",
    "dev:admin": "turbo run dev --filter=admin-dashboard",
    "build": "turbo run build",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:migrate": "pnpm --filter @salex/shared-types db:migrate",
    "db:migrate:create": "pnpm --filter @salex/shared-types db:migrate:create",
    "db:migrate:deploy": "pnpm --filter @salex/shared-types db:migrate:deploy",
    "db:migrate:status": "pnpm --filter @salex/shared-types db:migrate:status",
    "db:check-migration": "sh scripts/check-prisma-migration.sh",
    "db:push": "pnpm --filter @salex/shared-types db:push",
    "db:generate": "turbo run db:generate --filter=@salex/shared-types",
    "db:studio": "turbo run db:studio --filter=@salex/shared-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "axios": "^1.11.0",
    "turbo": "^2.0.14",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.7"
  },
  "packageManager": "pnpm@8.15.6",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "git add"
    ]
  },
  "pnpm": {
    "overrides": {
      "@types/react": "18.2.45",
      "@types/react-dom": "18.2.18"
    }
  }
}
